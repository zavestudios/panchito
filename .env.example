# Flask Configuration
FLASK_ENV=development
SECRET_KEY=change-me-local-dev-only
LOG_LEVEL=DEBUG
SESSION_COOKIE_SECURE=false

# Database Configuration
DB_USER=postgres
DB_PASSWORD=change-me-local-dev-only
DB_HOST=db
DB_PORT=5432
DB_NAME=example

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# OIDC / Keycloak
OIDC_ENABLED=false
OIDC_ISSUER_URL=https://sso.zavestudios.com/realms/zavestudios
OIDC_CLIENT_ID=panchito
OIDC_CLIENT_SECRET=change-me-local-dev-only
APP_BASE_URL=https://panchito-on-prem.zavestudios.com

# API Configuration
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=100
